rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Plants: public read, admin write
    match /plants/{plantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: own profile read/write, admin can read all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;

      // Plantings subcollection: own user only
      match /plantings/{plantingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Stock subcollection: own user only
      match /stock/{stockId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Config: public read, admin write
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
